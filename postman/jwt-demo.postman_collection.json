{
	"info": {
		"name": "JWT Demo API (Full Tests)",
		"_postman_id": "f7b2e3c1-9a4d-4f1e-bc1a-123456789abc",
		"description": "Full Postman collection for Spring Boot + Keycloak OAuth2 Proxy with tests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"clientId\": \"{{client_id}}\",\n  \"clientSecret\": \"{{client_secret}}\"\n}"
						},
						"url": "{{base_url}}/api/auth/login"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Login request succeeded\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const json = pm.response.json();",
									"",
									"pm.test(\"Response contains tokens\", function () {",
									"    pm.expect(json.data.access_token).to.be.a('string');",
									"    pm.expect(json.data.refresh_token).to.be.a('string');",
									"});",
									"",
									"pm.environment.set(\"access_token\", json.data.access_token);",
									"pm.environment.set(\"refresh_token\", json.data.refresh_token);",
									"",
									"console.log(\"Tokens updated in environment\");"
								]
							}
						}
					]
				},
				{
					"name": "Admin Login",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"{{admin}}\",\n  \"password\": \"{{admin_password}}\",\n  \"clientId\": \"{{client_id}}\",\n  \"clientSecret\": \"{{client_secret}}\"\n}"
						},
						"url": "{{base_url}}/api/auth/login"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Login request succeeded\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const json = pm.response.json();",
									"",
									"pm.test(\"Response contains tokens\", function () {",
									"    pm.expect(json.data.access_token).to.be.a('string');",
									"    pm.expect(json.data.refresh_token).to.be.a('string');",
									"});",
									"",
									"pm.environment.set(\"access_token\", json.data.access_token);",
									"pm.environment.set(\"refresh_token\", json.data.refresh_token);",
									"",
									"console.log(\"Tokens updated in environment\");"
								]
							}
						}
					]
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refresh_token}}\",\n  \"clientId\": \"{{client_id}}\",\n  \"clientSecret\": \"{{client_secret}}\"\n}"
						},
						"url": "{{base_url}}/api/auth/refresh"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Refresh succeeded\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const json = pm.response.json();",
									"",
									"pm.test(\"New tokens returned\", function () {",
									"    pm.expect(json.data.access_token).to.be.a('string');",
									"});",
									"",
									"pm.environment.set(\"access_token\", json.data.access_token);",
									"pm.environment.set(\"refresh_token\", json.data.refresh_token);",
									"",
									"console.log(\"Tokens refreshed\");"
								]
							}
						}
					]
				},
				{
					"name": "Revoke Token (Logout)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refresh_token}}\",\n  \"clientId\": \"{{client_id}}\",\n  \"clientSecret\": \"{{client_secret}}\"\n}"
						},
						"url": "{{base_url}}/api/auth/logout"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Logout succeeded\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"console.log(\"Refresh token revoked\");"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "Clients",
			"item": [
				{
					"name": "Create Client",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{access_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstName\": \"{{firstName}}\",\n  \"lastName\": \"{{lastName}}\",\n  \"phone\": \"{{phone}}\"\n}"
						},
						"url": "{{base_url}}/api/clients"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Create client succeeded\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"const json = pm.response.json();",
									"pm.test(\"Response contains client id and phone\", function () {",
									"    pm.expect(json.data.id).to.be.a('number');",
									"    pm.expect(json.data.phone).to.eql(pm.environment.get(\"phone\"));",
									"});",
									"pm.environment.set(\"id_client\", json.data.id);",
									"console.log(\"Client created, id set in environment\");"
								]
							}
						}
					]
				},
				{
					"name": "Get Client",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{access_token}}" }
						],
						"url": "{{base_url}}/api/clients/{{id_client}}"
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Get client succeeded\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"const json = pm.response.json();",
									"pm.test(\"Response contains expected id\", function () {",
									"    pm.expect(json.data.id).to.eql(Number(pm.environment.get(\"id_client\")));",
									"});",
									"console.log(\"Fetched client\");"
								]
							}
						}
					]
				}
			]
		}
	]
}